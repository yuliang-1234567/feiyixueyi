/**app.wxss**/
/* 全局样式 - 传统中国艺术风格 */
page {
  /* Brand */
  --fy-accent: #C8102E; /* 朱砂红 */
  --fy-accent-pressed: #A30D24;
  --fy-gold: #D4AF37; /* 鎏金点缀 */

  /* Neutrals */
  --fy-text: #2c2416;
  --fy-text-muted: #6b5d4f;
  --fy-border: rgba(139, 115, 85, 0.18);
  --fy-card: rgba(255, 255, 255, 0.86);
  --fy-card-solid: #ffffff;

  /* Effects */
  --fy-shadow-sm: 0 4rpx 20rpx rgba(44, 36, 22, 0.08);
  --fy-shadow-md: 0 10rpx 32rpx rgba(44, 36, 22, 0.12);
}

/* 通用 UI Tokens（避免各页面自建一套主题） */
.text-muted {
  color: var(--fy-text-muted);
}

.surface {
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 24rpx;
  box-shadow: var(--fy-shadow-sm);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.92);
  color: var(--fy-text);
  border: 2rpx solid var(--fy-border);
  box-shadow: none;
}

.btn-secondary:active {
  opacity: 0.96;
  transform: translateY(1rpx);
}

/* icon-badge：用 1 字短标替换 emoji 图标（不引入资源） */
.icon-badge {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  color: var(--fy-accent);
  background: rgba(200, 16, 46, 0.10);
  border: 2rpx solid rgba(200, 16, 46, 0.16);
  box-shadow: 0 10rpx 22rpx rgba(44, 36, 22, 0.08);
}

.icon-badge--muted {
  color: var(--fy-text);
  background: rgba(44, 36, 22, 0.05);
  border-color: rgba(139, 115, 85, 0.16);
}

.icon-badge--gold {
  color: rgba(44, 36, 22, 0.92);
  background: rgba(212, 175, 55, 0.16);
  border-color: rgba(212, 175, 55, 0.26);
}


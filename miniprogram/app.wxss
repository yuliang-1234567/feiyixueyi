.container {
  min-height: 100vh;
  background: transparent;
}

/* 通用按钮样式 */
button {
  border-radius: 14rpx;
  font-weight: 600;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

button::after {
  border: none;
}

button[type="primary"] {
  background: linear-gradient(135deg, var(--fy-accent) 0%, var(--fy-accent-pressed) 100%);
  border: none;
  box-shadow: 0 10rpx 26rpx rgba(200, 16, 46, 0.18);
  color: #fff;
}

button[type="primary"]:active {
  opacity: 0.96;
  transform: translateY(1rpx);
}

/* 通用文本样式 */
text {
  word-break: break-all;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

/* 通用卡片样式 */
.card {
  background: var(--fy-card);
  border-radius: 20rpx;
  border: 2rpx solid rgba(139, 115, 85, 0.16);
  box-shadow: var(--fy-shadow-sm);
  overflow: hidden;
}

/* 通用标签样式 */
.tag {
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.5s ease-out;
}


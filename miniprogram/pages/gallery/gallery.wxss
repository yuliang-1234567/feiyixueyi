/* pages/gallery/gallery.wxss */
.container {
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.category-filter {
  background: #fff;
  padding: 24rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border-radius: 0 0 24rpx 24rpx;
}

.filter-scroll {
  white-space: nowrap;
  width: 100%;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin: 0 12rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 40rpx;
  background: #f5f5f5;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  font-weight: 500;
}

.filter-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
  transform: scale(1.05);
}

.artwork-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  justify-content: space-between;
}

.artwork-item {
  width: 48%;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.artwork-item:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.artwork-image {
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.artwork-info {
  padding: 20rpx;
}

.artwork-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.artwork-category {
  font-size: 24rpx;
  color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 500;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.artwork-stats {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-item text {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.favorite-btn {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d5dcff;
  background: #f2f5ff;
  color: #5a6fc9;
  font-size: 22rpx;
  line-height: 1.6;
}

.favorite-btn.active {
  background: #ffeaf0;
  border-color: #ffb9c7;
  color: #d64161;
}

.loading,
.no-more,
.empty {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  padding: 200rpx 20rpx;
}


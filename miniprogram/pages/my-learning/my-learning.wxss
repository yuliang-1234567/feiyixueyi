.container {
  min-height: 100vh;
  background: transparent;
  padding: 28rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.clear-btn {
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(200, 16, 46, 0.14);
  padding: 0 24rpx;
  background: rgba(200, 16, 46, 0.08);
  color: var(--fy-accent);
  font-size: 24rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-item {
  display: flex;
  gap: 16rpx;
  background: var(--fy-card-solid);
  border: 2rpx solid var(--fy-border);
  border-radius: 18rpx;
  padding: 16rpx;
  box-shadow: var(--fy-shadow-sm);
}

.record-image {
  width: 170rpx;
  height: 170rpx;
  border-radius: 14rpx;
  background: #eef2f8;
}

.record-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.record-skill {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--fy-text);
}

.record-score {
  font-size: 26rpx;
  color: var(--fy-accent);
}

.record-time {
  font-size: 22rpx;
  color: var(--fy-text-muted);
}

.empty {
  margin-top: 180rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--fy-text-muted);
}
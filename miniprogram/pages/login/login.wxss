/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: transparent;
  padding: 80rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--fy-text-muted);
}

.form-card {
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: var(--fy-shadow-md);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--fy-text);
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(139, 115, 85, 0.22);
  font-size: 30rpx;
  background: rgba(255, 255, 255, 0.88);
}

.input:focus {
  border-color: rgba(200, 16, 46, 0.55);
  box-shadow: 0 0 0 2rpx rgba(200, 16, 46, 0.16);
  background: #fff;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(200, 16, 46, 0.22);
}

.helper {
  margin-top: 30rpx;
  text-align: center;
}

.link {
  font-size: 26rpx;
  color: var(--fy-accent);
}

.link:active {
  opacity: 0.7;
}

/* pages/about/about.wxss */
.container {
  background: transparent;
  min-height: 100vh;
}

.header {
  padding: 36rpx 30rpx 18rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.content {
  padding: 40rpx 30rpx;
}

.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
  padding: 60rpx 0;
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 20rpx;
  box-shadow: var(--fy-shadow-sm);
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--fy-text);
  margin-bottom: 12rpx;
}

.version {
  display: block;
  font-size: 26rpx;
  color: var(--fy-text-muted);
}

.info-section {
  margin-bottom: 40rpx;
}

.info-item {
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--fy-shadow-sm);
}

.info-label {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--fy-text);
  margin-bottom: 20rpx;
}

.info-text {
  display: block;
  font-size: 28rpx;
  color: var(--fy-text-muted);
  line-height: 1.8;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.copyright {
  font-size: 24rpx;
  color: var(--fy-text-muted);
}


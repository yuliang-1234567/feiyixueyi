/* pages/settings/settings.wxss */
.container {
  background: transparent;
  min-height: 100vh;
}

.header {
  padding: 36rpx 30rpx 18rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.settings-list {
  padding: 20rpx;
}

.setting-group {
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: var(--fy-shadow-sm);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(139, 115, 85, 0.14);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
}

.setting-badge {
  margin-right: 20rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
}

.setting-text {
  font-size: 28rpx;
  color: var(--fy-text);
}

.setting-arrow {
  font-size: 28rpx;
  color: rgba(107, 93, 79, 0.75);
}

.logout {
  justify-content: center;
  border-bottom: none;
}

.logout-text {
  font-size: 28rpx;
  color: #ff4444;
  font-weight: 600;
}


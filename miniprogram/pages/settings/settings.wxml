<!--pages/settings/settings.wxml-->
<view class="container">
  <view class="header">
    <text class="title">设置</text>
  </view>

  <view class="settings-list">
    <view class="setting-group">
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-text">消息通知</text>
        </view>
        <switch checked="{{settings.notifications}}" 
                data-key="notifications" 
                bindchange="toggleSetting" 
                color="#C8102E"/>
      </view>
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-text">自动播放</text>
        </view>
        <switch checked="{{settings.autoPlay}}" 
                data-key="autoPlay" 
                bindchange="toggleSetting" 
                color="#C8102E"/>
      </view>
    </view>

    <view class="setting-group">
      <view class="setting-item" bindtap="clearCache">
        <view class="setting-left">
          <text class="setting-text">清除缓存</text>
        </view>
        <text class="setting-arrow">></text>
      </view>
    </view>

    <view class="setting-group">
      <view class="setting-item logout" bindtap="logout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>
  </view>
</view>


/* pages/my-likes/my-likes.wxss */
.page {
  min-height: 100vh;
  background: transparent;
  padding: 28rpx;
  padding-bottom: 80rpx;
}

.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  padding: 34rpx;
  border-radius: 32rpx;
  box-shadow: var(--fy-shadow-md);
  color: var(--fy-text);
  margin-bottom: 40rpx;
}

.hero-badge {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  font-size: 34rpx;
}

.hero-info {
  flex: 1;
  padding-left: 30rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-desc {
  font-size: 26rpx;
  color: var(--fy-text-muted);
  margin-top: 12rpx;
}

.hero-count {
  background: rgba(44, 36, 22, 0.04);
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  text-align: right;
}

.count-number {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.count-label {
  font-size: 24rpx;
  opacity: 0.85;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.like-card {
  background: var(--fy-card-solid);
  border: 2rpx solid var(--fy-border);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--fy-shadow-sm);
}

.like-image {
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #ffe0e9 0%, #fef6f9 100%);
}

.like-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.like-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.like-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--fy-text);
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.like-category {
  font-size: 24rpx;
  color: var(--fy-accent);
  background: rgba(200, 16, 46, 0.08);
  border: 1rpx solid rgba(200, 16, 46, 0.14);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.like-desc {
  font-size: 26rpx;
  color: var(--fy-text-muted);
  line-height: 1.6;
  max-height: 80rpx;
  overflow: hidden;
}

.like-footer {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.like-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #999;
}

.stat-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  font-size: 20rpx;
  letter-spacing: 0;
  box-shadow: none;
}

.loading {
  text-align: center;
  margin-top: 120rpx;
  font-size: 28rpx;
  color: #999;
}

.empty {
  margin-top: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #999;
}

.empty-badge {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  font-size: 36rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  font-size: 26rpx;
  color: #888;
}


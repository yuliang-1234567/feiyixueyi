/* pages/ar/ar.wxss - 山水水墨风格 */
.container {
  width: 100%;
  height: 100vh;
  position: relative;
  background: linear-gradient(180deg, #fefcf8 0%, #f5f3ef 100%);
  overflow: hidden;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 扫描区域 */
.scan-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.scan-area {
  position: relative;
  width: 500rpx;
  height: 500rpx;
  border: 3rpx solid rgba(200, 16, 46, 0.6);
  border-radius: 24rpx;
  background: rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(4rpx);
}

.scan-corner {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #c8102e;
}

.scan-corner-tl {
  top: -2rpx;
  left: -2rpx;
  border-right: none;
  border-bottom: none;
  border-top-left-radius: 20rpx;
}

.scan-corner-tr {
  top: -2rpx;
  right: -2rpx;
  border-left: none;
  border-bottom: none;
  border-top-right-radius: 20rpx;
}

.scan-corner-bl {
  bottom: -2rpx;
  left: -2rpx;
  border-right: none;
  border-top: none;
  border-bottom-left-radius: 20rpx;
}

.scan-corner-br {
  bottom: -2rpx;
  right: -2rpx;
  border-left: none;
  border-top: none;
  border-bottom-right-radius: 20rpx;
}

.scan-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #c8102e, transparent);
  animation: scan 2s linear infinite;
  box-shadow: 0 0 10rpx rgba(200, 16, 46, 0.5);
}

@keyframes scan {
  0% {
    top: 0;
    opacity: 1;
  }
  50% {
    opacity: 0.8;
  }
  100% {
    top: 100%;
    opacity: 1;
  }
}

.scan-tip {
  margin-top: 40rpx;
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  background: rgba(139, 111, 71, 0.8);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
}

/* 顶部工具栏 */
.top-bar {
  position: absolute;
  top: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  padding: 0 40rpx;
  z-index: 20;
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(139, 111, 71, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(139, 111, 71, 0.15);
}

.tool-icon {
  font-size: 36rpx;
}

.tool-text {
  font-size: 20rpx;
  color: #8b6f47;
  font-weight: 600;
}

/* 底部控制栏 */
.control-bar {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 0 40rpx;
  z-index: 20;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.95) !important;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid #8b6f47 !important;
  border-radius: 24rpx !important;
  padding: 24rpx 40rpx !important;
  box-shadow: 0 4rpx 16rpx rgba(139, 111, 71, 0.25) !important;
}

.control-btn::after {
  border: none !important;
}

.scan-btn {
  background: linear-gradient(135deg, #c8102e 0%, #a00e24 100%) !important;
  color: #fff !important;
  border-color: #c8102e !important;
}

.image-btn {
  background: linear-gradient(135deg, #8b6f47 0%, #6b5d4f 100%) !important;
  color: #fff !important;
  border-color: #8b6f47 !important;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* AR信息面板 */
.ar-info {
  position: fixed;
  bottom: -100%;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  transition: bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  max-height: 70vh;
  overflow-y: auto;
  border-top: 4rpx solid #c8102e;
  box-shadow: 0 -8rpx 32rpx rgba(139, 111, 71, 0.2);
  z-index: 100;
}

.ar-info.show {
  bottom: 0;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #e8e0d6;
}

.info-title-wrapper {
  flex: 1;
}

.info-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2c2416;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.info-category {
  display: inline-block;
  font-size: 22rpx;
  color: #8b6f47;
  background: rgba(139, 111, 71, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid #8b6f47;
}

.close-btn {
  font-size: 56rpx;
  color: #999;
  line-height: 1;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 111, 71, 0.1);
  border-radius: 50%;
}

.info-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.info-image-wrapper {
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #e8e0d6;
  box-shadow: 0 4rpx 12rpx rgba(139, 111, 71, 0.1);
}

.info-image {
  width: 100%;
  max-height: 400rpx;
  display: block;
}

.info-section {
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #8b6f47;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: #2c2416;
  line-height: 1.8;
  text-align: justify;
}

.info-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #e8e0d6;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #8b6f47 0%, #6b5d4f 100%) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 16rpx !important;
  padding: 20rpx !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 4rpx 12rpx rgba(139, 111, 71, 0.3) !important;
}

.action-btn::after {
  border: none !important;
}

.audio-btn.playing {
  background: linear-gradient(135deg, #c8102e 0%, #a00e24 100%) !important;
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 28rpx;
}

/* 内容列表 */
.content-list,
.history-list {
  position: fixed;
  bottom: -100%;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx 40rpx 0 0;
  max-height: 70vh;
  border-top: 4rpx solid #8b6f47;
  box-shadow: 0 -8rpx 32rpx rgba(139, 111, 71, 0.2);
  z-index: 100;
  transition: bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.content-list.show,
.history-list.show {
  bottom: 0;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 2rpx solid #e8e0d6;
}

.list-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c2416;
  letter-spacing: 2rpx;
}

.list-scroll {
  max-height: calc(70vh - 120rpx);
}

.content-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.content-item:active {
  background: rgba(139, 111, 71, 0.05);
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e8e0d6;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c2416;
}

.item-category {
  font-size: 24rpx;
  color: #8b6f47;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:active {
  background: rgba(139, 111, 71, 0.05);
}

.history-icon {
  font-size: 40rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139, 111, 71, 0.1);
  border-radius: 50%;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2416;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-arrow {
  font-size: 40rpx;
  color: #8b6f47;
}

.empty-tip {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 加载提示 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  padding: 40rpx 60rpx;
  border-radius: 24rpx;
  border: 2rpx solid #8b6f47;
  box-shadow: 0 8rpx 32rpx rgba(139, 111, 71, 0.3);
}

.loading-icon {
  font-size: 60rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #8b6f47;
  font-weight: 600;
  letter-spacing: 2rpx;
}


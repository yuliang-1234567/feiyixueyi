<!--pages/index/index.wxml-->
<view class="container">
  <!-- Hero -->
  <view class="hero">
    <image class="hero-bg" src="{{hero.bgUrl}}" mode="aspectFill" />
    <view class="hero-overlay"></view>
    <view class="hero-content">
      <view class="hero-badge">{{hero.badge}}</view>
      <view class="hero-title">{{hero.title}}</view>
      <view class="hero-subtitle">{{hero.subtitle}}</view>
      <view class="hero-actions">
        <button class="hero-btn-primary" type="primary" bindtap="handleHeroPrimary">开始学习</button>
        <button class="hero-btn-secondary" bindtap="handleHeroSecondary">查看作品</button>
      </view>
    </view>
  </view>

  <!-- 核心模块 -->
  <view class="feature-section">
    <view class="section-header">
      <text class="section-title">核心模块</text>
    </view>
    <view class="modules-grid">
      <view
        class="module-card"
        wx:for="{{modules}}"
        wx:key="id"
        data-url="{{item.url}}"
        data-nav="{{item.nav}}"
        bindtap="navigateToFeature"
      >
        <image class="module-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="module-info">
          <view class="module-title">{{item.title}}</view>
          <view class="module-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 继续学习 -->
  <view class="recents-section">
    <view class="section-header">
      <text class="section-title">继续学习</text>
      <text class="section-more" bindtap="goToAiLearn">去学艺 ></text>
    </view>

    <view wx:if="{{recents.length === 0}}" class="recents-empty card">
      <view class="recents-emptyTitle">还没有学习记录</view>
      <view class="recents-emptyText">从 AI 学艺开始，首页会自动记录你的进度。</view>
      <button type="primary" class="recents-emptyBtn" bindtap="goToAiLearn">开始学艺</button>
    </view>

    <view wx:else class="recents-list">
      <view class="recent-item card" wx:for="{{recents}}" wx:key="id" bindtap="goToAiLearn">
        <view class="recent-left">
          <view class="recent-title">{{item.skillName}}</view>
          <view class="recent-meta">相似度 {{item.score}}%</view>
        </view>
        <view class="recent-right">继续</view>
      </view>
    </view>
  </view>

  <!-- 大师风采（复用精选作品） -->
  <view class="masters-section" wx:if="{{masters.length > 0}}">
    <view class="section-header">
      <text class="section-title">大师风采</text>
      <text class="section-more" bindtap="navigateToGallery">更多 ></text>
    </view>
    <scroll-view class="masters-scroll" scroll-x="true">
      <view class="masters-list">
        <view class="master-card" wx:for="{{masters}}" wx:key="id" data-id="{{item.id}}" bindtap="navigateToArtwork">
          <image class="master-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true" />
          <view class="master-info">
            <view class="master-title">{{item.title}}</view>
            <view class="master-tag">{{item.category}}</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 地域探索入口 -->
  <view class="map-entry card" bindtap="navigateToFeature" data-url="/pages/learn/learn" data-nav="tab">
    <view class="map-entryTitle">地域探索</view>
    <view class="map-entryDesc">从一省一艺出发，找到你的文化坐标</view>
    <view class="map-entryCta">开启 ></view>
  </view>

  <!-- 推荐作品 -->
  <view class="artwork-section" wx:if="{{featuredArtworks.length > 0}}">
    <view class="section-header">
      <text class="section-title">推荐作品</text>
      <text class="section-more" bindtap="navigateToGallery">更多 ></text>
    </view>
    <scroll-view class="artwork-scroll" scroll-x="true">
      <view class="artwork-list">
        <view class="artwork-item" wx:for="{{featuredArtworks}}" wx:key="id" data-id="{{item.id}}" bindtap="navigateToArtwork">
          <image src="{{item.imageUrl}}" mode="aspectFill" class="artwork-image" lazy-load="true"></image>
          <view class="artwork-info">
            <text class="artwork-title">{{item.title}}</text>
            <view class="artwork-meta">
              <text class="artwork-category">{{item.category}}</text>
              <text class="artwork-stats">
                <text class="artwork-likeDot"></text>
                {{item.likesCount || 0}}
              </text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>


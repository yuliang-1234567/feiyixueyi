/* pages/index/index.wxss */
.container {
  background: linear-gradient(180deg, #fefcf8 0%, #faf9f6 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Hero */
.hero {
  position: relative;
  height: 560rpx;
  margin: 20rpx 20rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--fy-shadow-md);
  border: 2rpx solid rgba(139, 115, 85, 0.16);
}

.hero-bg {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.18) 70%);
}

.hero-content {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  color: #fff;
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  margin-bottom: 10rpx;
  text-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.25);
}

.hero-subtitle {
  font-size: 26rpx;
  opacity: 0.92;
  line-height: 1.7;
  margin-bottom: 18rpx;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
}

.hero-btn-primary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
}

.hero-btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(255, 255, 255, 0.92);
  color: rgba(44, 36, 22, 0.92);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.14);
}

.hero-btn-secondary:active {
  opacity: 0.94;
  transform: translateY(1rpx);
}

/* 通用section样式 */
.feature-section,
.recents-section,
.masters-section,
.map-entry,
.category-section,
.artwork-section,
.product-section {
  background: rgba(255, 255, 255, 0.86);
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  border-radius: 24rpx;
  box-shadow: var(--fy-shadow-sm);
  margin-left: 20rpx;
  margin-right: 20rpx;
  border: 2rpx solid rgba(139, 115, 85, 0.14);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--fy-text);
  letter-spacing: -1rpx;
}

.section-more {
  font-size: 26rpx;
  color: var(--fy-accent);
  font-weight: 700;
}

/* 分类列表 */
.category-list {
  display: flex;
  justify-content: space-around;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.category-icon-wrapper {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(200, 16, 46, 0.10);
  border: 2rpx solid rgba(200, 16, 46, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 26rpx rgba(200, 16, 46, 0.10);
  transition: all 0.3s;
}

.category-icon-wrapper:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.category-iconText {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--fy-accent);
}

.category-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 核心模块卡片 */
.modules-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.module-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(139, 115, 85, 0.14);
  box-shadow: var(--fy-shadow-sm);
}

.module-card:active {
  transform: translateY(1rpx);
  opacity: 0.98;
}

.module-image {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, rgba(200, 16, 46, 0.06) 0%, rgba(212, 175, 55, 0.06) 100%);
}

.module-info {
  padding: 18rpx 18rpx 16rpx;
}

.module-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--fy-text);
  margin-bottom: 8rpx;
}

.module-desc {
  font-size: 24rpx;
  color: var(--fy-text-muted);
  line-height: 1.55;
}

/* 继续学习 */
.recents-empty {
  padding: 24rpx;
}

.recents-emptyTitle {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--fy-text);
  margin-bottom: 10rpx;
}

.recents-emptyText {
  font-size: 24rpx;
  color: var(--fy-text-muted);
  line-height: 1.75;
}

.recents-emptyBtn {
  margin-top: 18rpx;
}

.recents-list {
  display: grid;
  gap: 14rpx;
}

.recent-item {
  padding: 18rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recent-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--fy-text);
  margin-bottom: 4rpx;
}

.recent-meta {
  font-size: 24rpx;
  color: var(--fy-text-muted);
}

.recent-right {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--fy-accent);
  background: rgba(200, 16, 46, 0.10);
  border: 2rpx solid rgba(200, 16, 46, 0.14);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

/* 大师风采 */
.masters-scroll {
  white-space: nowrap;
  width: 100%;
}

.masters-list {
  display: inline-flex;
  gap: 18rpx;
  padding: 0 2rpx;
}

.master-card {
  width: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(139, 115, 85, 0.14);
  box-shadow: var(--fy-shadow-sm);
}

.master-card:active {
  transform: scale(0.99);
}

.master-image {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, rgba(200, 16, 46, 0.06) 0%, rgba(212, 175, 55, 0.06) 100%);
}

.master-info {
  padding: 16rpx 16rpx 14rpx;
}

.master-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--fy-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.master-tag {
  font-size: 22rpx;
  color: var(--fy-accent);
  background: rgba(200, 16, 46, 0.08);
  border: 2rpx solid rgba(200, 16, 46, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  display: inline-block;
}

/* 地域探索入口 */
.map-entry {
  padding: 26rpx 26rpx;
  margin-bottom: 30rpx;
}

.map-entryTitle {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--fy-text);
  margin-bottom: 8rpx;
}

.map-entryDesc {
  font-size: 24rpx;
  color: var(--fy-text-muted);
  line-height: 1.7;
}

.map-entryCta {
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: var(--fy-accent);
}

/* 作品区域 */
.artwork-section {
  background: #fff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.artwork-scroll {
  white-space: nowrap;
  width: 100%;
}

.artwork-list {
  display: inline-flex;
  padding: 0 30rpx;
  gap: 20rpx;
}

.artwork-item {
  width: 300rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
  transition: all 0.3s;
}

.artwork-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.artwork-image {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.artwork-info {
  padding: 20rpx;
}

.artwork-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.artwork-category {
  font-size: 22rpx;
  color: var(--fy-accent);
  background: rgba(200, 16, 46, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.artwork-stats {
  font-size: 22rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.artwork-likeDot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(200, 16, 46, 0.85);
  display: inline-block;
  margin-right: 6rpx;
}

/* 商品列表 */
.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-item {
  width: 48%;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.product-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.product-image {
  width: 100%;
  height: 340rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.product-info {
  padding: 20rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  color: #ff4444;
  font-weight: bold;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

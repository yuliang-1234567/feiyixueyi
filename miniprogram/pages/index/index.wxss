/* pages/index/index.wxss */
.container {
  background: linear-gradient(180deg, #fefcf8 0%, #faf9f6 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 轮播图区域（从web端移植） */
.carousel-section {
  width: 100%;
  padding: 40rpx 30rpx;
  background: #fff;
  margin-bottom: 30rpx;
}

.carousel-metadata {
  text-align: center;
  margin-bottom: 40rpx;
}

.carousel-main-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  letter-spacing: 0.05em;
  line-height: 1.3;
}

.carousel-meta-info {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: #666;
  margin-top: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-label {
  font-weight: 500;
  color: #999;
}

.meta-value {
  color: #666;
}

.carousel-main-display {
  margin-bottom: 30rpx;
}

.carousel-image-wrapper {
  position: relative;
  width: 100%;
  max-width: 750rpx;
  height: 600rpx;
  margin: 0 auto;
  background: linear-gradient(180deg, #f5f6f9 0%, #eef1f7 100%);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.carousel-main-image {
  width: 520rpx;
  height: 520rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  object-fit: contain;
}

.carousel-nav-button {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 78rpx;
  height: 78rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.carousel-nav-prev {
  left: 20rpx;
}

.carousel-nav-next {
  right: 20rpx;
}

.nav-arrow-text {
  font-size: 42rpx;
  color: #666;
  line-height: 1;
  font-weight: 600;
}

.carousel-image-title {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  background: rgba(255, 255, 255, 0.95);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.carousel-page-indicator {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  font-size: 24rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.9);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.carousel-thumbnails {
  width: 100%;
  overflow: hidden;
}

.carousel-thumbnails-scroll {
  width: 100%;
  white-space: nowrap;
}

.carousel-thumbnails-container {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 20rpx;
}

.carousel-thumbnail {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.carousel-thumbnail-image {
  width: 100%;
  height: 100%;
}

.carousel-thumbnail.active {
  border: 2rpx solid #1890ff;
}

.carousel-thumbnail-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 2rpx solid #667eea;
  border-radius: 12rpx;
  box-sizing: border-box;
  pointer-events: none;
}

/* 通用section样式 */
.category-section,
.feature-section,
.artwork-section,
.product-section {
  background: #fff;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-left: 20rpx;
  margin-right: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
}

.section-more {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* 分类列表 */
.category-list {
  display: flex;
  justify-content: space-around;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.category-icon-wrapper {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
}

.category-icon-wrapper:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.category-icon {
  font-size: 52rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.category-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 功能入口 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon-wrapper {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
  transition: all 0.3s;
}

.feature-icon-wrapper:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);
}

.feature-icon {
  font-size: 44rpx;
}

.feature-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 作品区域 */
.artwork-section {
  background: #fff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.artwork-scroll {
  white-space: nowrap;
  width: 100%;
}

.artwork-list {
  display: inline-flex;
  padding: 0 30rpx;
  gap: 20rpx;
}

.artwork-item {
  width: 300rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
  transition: all 0.3s;
}

.artwork-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.artwork-image {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.artwork-info {
  padding: 20rpx;
}

.artwork-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.artwork-category {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f4ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.artwork-stats {
  font-size: 22rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.artwork-stats text {
  font-size: 22rpx;
  margin-right: 4rpx;
}

/* 商品列表 */
.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-item {
  width: 48%;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.product-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.product-image {
  width: 100%;
  height: 340rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.product-info {
  padding: 20rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  color: #ff4444;
  font-weight: bold;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

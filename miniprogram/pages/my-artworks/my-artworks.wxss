/* pages/my-artworks/my-artworks.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9ff 0%, #ffffff 100%);
  padding: 40rpx;
  padding-bottom: 80rpx;
}

.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(102, 126, 234, 0.25);
  color: #fff;
  margin-bottom: 40rpx;
}

.hero-icon {
  font-size: 68rpx;
  background: rgba(255, 255, 255, 0.2);
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 4rpx rgba(255, 255, 255, 0.25);
}

.hero-info {
  flex: 1;
  padding-left: 30rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-desc {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 12rpx;
}

.hero-count {
  background: rgba(255, 255, 255, 0.2);
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  text-align: right;
}

.count-number {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.count-label {
  font-size: 24rpx;
  opacity: 0.85;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.art-card {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.08);
}

.art-image {
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.art-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.art-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.art-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.art-category {
  font-size: 24rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.12);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.art-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  max-height: 80rpx;
  overflow: hidden;
}

.art-footer {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.art-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #999;
}

.stat-icon {
  font-size: 28rpx;
}

.loading {
  text-align: center;
  margin-top: 120rpx;
  font-size: 28rpx;
  color: #999;
}

.empty {
  margin-top: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #999;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-desc {
  font-size: 26rpx;
  color: #888;
}


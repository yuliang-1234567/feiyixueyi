.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fefcf8 0%, #faf9f6 100%);
  padding: 30rpx;
}

.step-container {
  max-width: 750rpx;
  margin: 0 auto;
}

.step-header {
  text-align: center;
  margin-bottom: 56rpx;
}

.step-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--fy-text);
  margin-bottom: 16rpx;
}

.step-desc {
  display: block;
  font-size: 28rpx;
  color: var(--fy-text-muted);
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 24rpx;
}

.skill-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 34rpx 16rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 20rpx;
  box-shadow: var(--fy-shadow-sm);
  border: 2rpx solid rgba(139, 115, 85, 0.14);
  transition: opacity 0.2s, transform 0.2s;
}

.skill-card:active {
  opacity: 0.96;
  transform: translateY(1rpx);
  border-color: rgba(200, 16, 46, 0.22);
}

.skill-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: rgba(200, 16, 46, 0.06);
  border: 2rpx solid rgba(200, 16, 46, 0.14);
  color: var(--fy-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.skill-icon-image {
  width: 56rpx;
  height: 56rpx;
}

.skill-name {
  font-size: 26rpx;
  color: var(--fy-text);
  font-weight: 500;
}

.selected-skill {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 44rpx;
}

.skill-icon-large {
  width: 136rpx;
  height: 136rpx;
  border-radius: 999rpx;
  background: rgba(200, 16, 46, 0.06);
  border: 2rpx solid rgba(200, 16, 46, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fy-accent);
  font-size: 64rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.skill-icon-large-image {
  width: 84rpx;
  height: 84rpx;
}

.skill-name-large {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fy-accent);
}

.upload-area {
  width: 100%;
  height: 460rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: var(--fy-shadow-sm);
  border: 2rpx solid rgba(139, 115, 85, 0.14);
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(200, 16, 46, 0.04);
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(139, 115, 85, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fy-accent);
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--fy-text-muted);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.analyzing-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
}

.loading-animation {
  margin-bottom: 34rpx;
}

.spinner {
  width: 84rpx;
  height: 84rpx;
  border-radius: 999rpx;
  border: 6rpx solid rgba(200, 16, 46, 0.14);
  border-top-color: rgba(200, 16, 46, 0.75);
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.analyzing-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--fy-text);
  margin-bottom: 16rpx;
}

.analyzing-desc {
  font-size: 24rpx;
  color: var(--fy-text-muted);
}

.result-card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--fy-shadow-sm);
  border: 2rpx solid rgba(139, 115, 85, 0.14);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(139, 115, 85, 0.14);
  margin-bottom: 24rpx;
}

.result-label {
  font-size: 28rpx;
  color: var(--fy-text-muted);
}

.result-score {
  font-size: 46rpx;
  font-weight: 700;
  color: var(--fy-accent);
}

.result-details {
  margin-bottom: 26rpx;
}

.detail-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--fy-text);
  margin-bottom: 18rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 18rpx;
  background: rgba(44, 36, 22, 0.035);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(139, 115, 85, 0.12);
}

.suggestion-text {
  font-size: 26rpx;
  color: var(--fy-text-muted);
  line-height: 1.6;
}

.bullet {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  margin-top: 10rpx;
  flex: 0 0 auto;
}

.bullet-good {
  background: rgba(212, 175, 55, 0.85);
}

.bullet-tip {
  background: rgba(200, 16, 46, 0.75);
}

.bullet-plan {
  background: rgba(139, 115, 85, 0.65);
}

.action-buttons {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.btn-primary {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, var(--fy-accent) 0%, var(--fy-accent-pressed) 100%);
  color: #fff;
  border: none;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 26rpx rgba(200, 16, 46, 0.18);
}

.btn-secondary {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  background: rgba(255, 255, 255, 0.90);
  color: var(--fy-text);
  border: 2rpx solid rgba(139, 115, 85, 0.18);
  border-radius: 42rpx;
  font-size: 30rpx;
}

.btn-secondary:active {
  opacity: 0.96;
  transform: translateY(1rpx);
}

.user-work-section {
  margin-bottom: 24rpx;
}

.user-work-image {
  width: 100%;
  height: 360rpx;
  border-radius: 10rpx;
  margin-top: 16rpx;
  background: #f8f9fa;
}

.learning-plan {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.plan-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.plan-text {
  font-size: 26rpx;
  color: var(--fy-text-muted);
  line-height: 1.65;
}
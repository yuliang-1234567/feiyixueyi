.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fc 0%, #ffffff 100%);
  padding: 30rpx;
}

.step-container {
  max-width: 750rpx;
  margin: 0 auto;
}

.step-header {
  text-align: center;
  margin-bottom: 56rpx;
}

.step-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.step-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 24rpx;
}

.skill-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 34rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.skill-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.skill-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.selected-skill {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 44rpx;
}

.skill-icon-large {
  font-size: 110rpx;
  margin-bottom: 16rpx;
}

.skill-name-large {
  font-size: 34rpx;
  font-weight: 600;
  color: #667eea;
}

.upload-area {
  width: 100%;
  height: 460rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
}

.upload-icon {
  font-size: 110rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #999;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.analyzing-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
}

.loading-animation {
  margin-bottom: 34rpx;
}

.spinner {
  font-size: 110rpx;
  display: inline-block;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.analyzing-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.analyzing-desc {
  font-size: 24rpx;
  color: #999;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.result-label {
  font-size: 28rpx;
  color: #666;
}

.result-score {
  font-size: 46rpx;
  font-weight: 700;
  color: #667eea;
}

.result-details {
  margin-bottom: 26rpx;
}

.detail-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 18rpx;
}

.suggestion-item {
  padding: 18rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.btn-primary {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-secondary {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  background: #f1f3f8;
  color: #666;
  border: none;
  border-radius: 42rpx;
  font-size: 30rpx;
}

.user-work-section {
  margin-bottom: 24rpx;
}

.user-work-image {
  width: 100%;
  height: 360rpx;
  border-radius: 10rpx;
  margin-top: 16rpx;
  background: #f8f9fa;
}

.learning-plan {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.plan-item {
  font-size: 26rpx;
  color: #555;
}
<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-card" wx:if="{{hasUserInfo}}">
      <image src="{{avatar}}" class="avatar" mode="aspectFill"></image>
      <view class="user-info">
        <text class="username">{{displayName}}</text>
        <text class="user-email" wx:if="{{displayEmail}}">{{displayEmail}}</text>
        <text class="user-desc">欢迎回到非遗技艺平台</text>
      </view>
    </view>

    <view class="login-card" wx:else>
      <view class="icon-badge icon-badge--muted">登</view>
      <text class="login-title">欢迎使用非遗技艺平台</text>
      <text class="login-subtitle">使用与 Web 端相同的账号密码登录，解锁完整功能</text>
      <button class="login-btn" type="primary" bindtap="handleLogin">立即登录</button>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section" wx:if="{{hasUserInfo}}">
    <view class="stat-card" bindtap="navigateToMyLearning">
      <view class="icon-badge">学</view>
      <view class="stat-content">
        <text class="stat-value">{{stats.learningRecords}}</text>
        <text class="stat-label">学习记录</text>
      </view>
    </view>
    <view class="stat-card" bindtap="navigateToMyLikes">
      <view class="icon-badge icon-badge--gold">藏</view>
      <view class="stat-content">
        <text class="stat-value">{{stats.likes}}</text>
        <text class="stat-label">收藏</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="navigateToMyLearning">
        <view class="menu-left">
          <view class="icon-badge">学</view>
          <view class="menu-texts">
            <text class="menu-title">我的学习记录</text>
            <text class="menu-desc">查看每次学艺评分与时间</text>
          </view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateToMyLikes">
        <view class="menu-left">
          <view class="icon-badge icon-badge--gold">藏</view>
          <view class="menu-texts">
            <text class="menu-title">我的收藏</text>
            <text class="menu-desc">收藏的作品与商品</text>
          </view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="navigateToSettings">
        <view class="menu-left">
          <view class="icon-badge icon-badge--muted">设</view>
          <view class="menu-texts">
            <text class="menu-title">设置</text>
            <text class="menu-desc">通知、缓存等偏好管理</text>
          </view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateToAbout">
        <view class="menu-left">
          <view class="icon-badge icon-badge--muted">关</view>
          <view class="menu-texts">
            <text class="menu-title">关于我们</text>
            <text class="menu-desc">了解平台使命与联系方式</text>
          </view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>


/* pages/profile/profile.wxss */
.container {
  background: transparent;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.user-section {
  position: relative;
  padding: 24rpx 24rpx 0;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 30rpx;
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  padding: 34rpx;
  border-radius: 32rpx;
  box-shadow: var(--fy-shadow-md);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(200, 16, 46, 0.10);
  box-shadow: 0 12rpx 24rpx rgba(44, 36, 22, 0.16);
  background: #fff;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: var(--fy-text);
}

.username {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.user-email {
  font-size: 26rpx;
  color: var(--fy-text-muted);
}

.user-desc {
  font-size: 28rpx;
  color: var(--fy-text-muted);
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 20rpx;
  padding: 54rpx 36rpx;
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 32rpx;
  box-shadow: var(--fy-shadow-md);
  color: var(--fy-text);
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
}

.login-subtitle {
  font-size: 26rpx;
  color: var(--fy-text-muted);
  line-height: 1.6;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.stats-section {
  margin: 22rpx 24rpx 24rpx;
  display: flex;
  gap: 24rpx;
}

.stat-card {
  flex: 1;
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 28rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: var(--fy-shadow-sm);
}

.stat-icon-frame {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(200, 16, 46, 0.16);
  background: rgba(200, 16, 46, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(44, 36, 22, 0.06);
  flex-shrink: 0;
}

.stat-icon-frame--gold {
  border-color: rgba(212, 175, 55, 0.28);
  background: rgba(212, 175, 55, 0.10);
}

.stat-icon {
  width: 50rpx;
  height: 50rpx;
}

.stat-card:active {
  transform: scale(0.98);
  transition: transform 0.2s;
}

.stat-content {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.stat-label {
  width: max-content;
  font-size: 24rpx;
  color: var(--fy-text-muted);
}

.menu-section {
  padding: 0 24rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.menu-group {
  background: var(--fy-card);
  border: 2rpx solid var(--fy-border);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--fy-shadow-sm);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(139, 115, 85, 0.14);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon-frame {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(200, 16, 46, 0.14);
  background: rgba(200, 16, 46, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(44, 36, 22, 0.05);
  flex-shrink: 0;
}

.menu-icon-frame--gold {
  border-color: rgba(212, 175, 55, 0.26);
  background: rgba(212, 175, 55, 0.10);
}

.menu-icon-frame--muted {
  border-color: rgba(139, 115, 85, 0.20);
  background: rgba(44, 36, 22, 0.04);
}

.menu-icon {
  width: 50rpx;
  height: 50rpx;
}

.menu-texts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--fy-text);
}

.menu-desc {
  font-size: 24rpx;
  color: var(--fy-text-muted);
}

.menu-arrow {
  font-size: 40rpx;
  color: #c0c0c0;
}

/* pages/profile/profile.wxss */
.container {
  background: linear-gradient(180deg, #f5f7fb 0%, #ffffff 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.user-section {
  position: relative;
  padding: 20rpx;
  margin-bottom: 150rpx;
  overflow: hidden;
}

.gradient-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0.95;
  border-radius: 0 0 20rpx 20rpx;
}

.user-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  padding: 40rpx;
  border-radius: 32rpx;
  backdrop-filter: blur(12rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.18);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.2);
  background: #fff;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #fff;
}

.username {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.user-email {
  font-size: 26rpx;
  opacity: 0.85;
}

.user-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.login-card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 20rpx;
  padding: 60rpx 40rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  backdrop-filter: blur(12rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.18);
  color: #fff;
}

.login-icon {
  font-size: 96rpx;
  filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.25));
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
}

.login-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1.6;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ffffff 0%, rgba(255, 255, 255, 0.8) 100%);
  color: #667eea;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.18);
}

.stats-section {
  margin: -140rpx 40rpx 40rpx;
  display: flex;
  gap: 24rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 28rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(102, 126, 234, 0.15);
}

.stat-card:active {
  transform: scale(0.98);
  transition: transform 0.2s;
}

.stat-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.12);
}

.stat-icon.artworks {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stat-icon.likes {
  background: linear-gradient(135deg, #ff758c 0%, #ff7eb3 100%);
}

.stat-icon.learning {
  background: linear-gradient(135deg, #4f68cd 0%, #6e7ff5 100%);
}

.stat-icon.orders {
  background: linear-gradient(135deg, #42e695 0%, #3bb2b8 100%);
}

.stat-content {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.stat-label {
  width: max-content;
  font-size: 24rpx;
  color: #666;
}

.menu-section {
  padding: 0 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.menu-group {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #fff;
}

.icon-orders {
  background: linear-gradient(135deg, #42e695 0%, #3bb2b8 100%);
}

.icon-artworks {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.icon-likes {
  background: linear-gradient(135deg, #ff758c 0%, #ff7eb3 100%);
}

.icon-learning {
  background: linear-gradient(135deg, #4f68cd 0%, #6e7ff5 100%);
}

.icon-settings {
  background: linear-gradient(135deg, #43cea2 0%, #185a9d 100%);
}

.icon-about {
  background: linear-gradient(135deg, #89f7fe 0%, #66a6ff 100%);
}

.menu-texts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 40rpx;
  color: #c0c0c0;
}

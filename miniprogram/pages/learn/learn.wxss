.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fefcf8 0%, #faf9f6 100%);
  padding: 28rpx;
}

.hero {
  margin-bottom: 22rpx;
}

.hero-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--fy-text-muted);
  line-height: 1.6;
}

.map-card {
  background: rgba(255, 255, 255, 0.86);
  border-radius: 24rpx;
  padding: 26rpx;
  box-shadow: var(--fy-shadow-sm);
  border: 2rpx solid rgba(139, 115, 85, 0.14);
}

.map-head {
  margin-bottom: 20rpx;
}

.map-figure {
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid rgba(139, 115, 85, 0.14);
  background: rgba(44, 36, 22, 0.03);
  box-shadow: var(--fy-shadow-sm);
  margin-bottom: 18rpx;
}

.map-image {
  width: 100%;
  height: 260rpx;
  display: block;
}

/* 取消 echarts canvas，使用静态图占位 */

.panel-image {
  width: 100%;
  height: 300rpx;
  border-radius: 18rpx;
  margin: 12rpx 0 14rpx;
  overflow: hidden;
  background: rgba(44, 36, 22, 0.03);
  border: 2rpx solid rgba(139, 115, 85, 0.14);
}

.map-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--fy-text);
}

.map-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--fy-text-muted);
}

.map-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.keyword {
  font-size: 22rpx;
  color: var(--fy-accent);
  background: rgba(200, 16, 46, 0.08);
  border: 1rpx solid rgba(200, 16, 46, 0.14);
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}

.search-box {
  height: 74rpx;
  border: 1rpx solid rgba(139, 115, 85, 0.22);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 18rpx;
  background: rgba(255, 255, 255, 0.88);
}

.search-input {
  flex: 1;
  font-size: 26rpx;
}

.search-clear {
  color: var(--fy-accent);
  font-size: 24rpx;
}

.province-scroll {
  height: 720rpx;
}

.province-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  padding-bottom: 10rpx;
}

.province-item {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(139, 115, 85, 0.18);
  border-radius: 14rpx;
  padding: 16rpx;
}

.province-item:active {
  background: rgba(200, 16, 46, 0.06);
}

.province-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--fy-text);
}

.province-heritage {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--fy-text-muted);
}

.panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 99;
}

.panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx;
  max-height: 70vh;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--fy-text);
  margin-bottom: 16rpx;
}

.panel-content-wrap {
  max-height: 36vh;
}

.panel-content {
  font-size: 27rpx;
  color: var(--fy-text-muted);
  line-height: 1.8;
}

.panel-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border: none;
  border-radius: 14rpx;
  background: var(--fy-accent);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}